/figures/build/geometry3d/*/review/

# Generated figure companions are not committed by default; canonical assets are PNG
/figures/build/**/*.pdf
/figures/build/**/*.svg

# Figure-generation prompts belong under figures/src/... alongside the figure source
/prompts/

